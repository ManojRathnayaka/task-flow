# =============================================================================
# Task Manager Application Environment Configuration Template
# =============================================================================
# Rename this file to '.env' and fill in your desired credentials before starting
# the containers.

# -----------------------------------------------------------------------------
# 1. PostgreSQL Database Configuration
# -----------------------------------------------------------------------------
# These credentials will be used to initialize the PostgreSQL container and 
# configure the Spring Boot application to connect to it.
DB_USER=task_user
DB_PASSWORD=ChangeThisPasswordToSomethingSecure123!
DB_NAME=taskmanager

# -----------------------------------------------------------------------------
# 2. JWT Security Configuration
# -----------------------------------------------------------------------------
# The secret key must be at least 256 bits (32 characters long) to support 
# HMAC-SHA256 token signing. Do not use the default in production!
JWT_SECRET=ChangeThisToAVeryLongSuperSecretKeyForJWTTokenSigningWith256BitsMinimum!
